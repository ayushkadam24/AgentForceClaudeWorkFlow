    <!-- VS-20 (REQ-053/C5.1/D-031): READ on Patient/Appointment so facility staff can see their OWN
         facility's citizens/appointments. Row visibility is gated by Apex managed sharing
         (VS_Facility_Access__c), NOT by these object perms — without object+field read the sharing would
         be meaningless (records stay invisible) and the SHIP-BAR test could not prove scoping. viewAll
         stays false (that is the District mechanism). Read-only: staff-initiated create/cancel/check-in
         is a later ticket; the appointment share is Edit-capable but the permset caps effective access at
         Read for now (least-privilege). NOTE: VS-04 deferred these grants to VS-20; this is that grant. -->
    <objectPermissions>
        <object>VS_Patient__c</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
