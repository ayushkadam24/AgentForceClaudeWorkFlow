<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VS_Severity__c</fullName>
    <label>Severity</label>
    <description>Severity of the logged event. Values: Info, Warning, Error. Defaults to Error since most fault-connector writes represent a failed automation step; Info/Warning are available for future non-fault diagnostic logging.</description>
    <type>Picklist</type>
    <required>true</required>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Info</fullName>
                <default>false</default>
                <label>Info</label>
            </value>
            <value>
                <fullName>Warning</fullName>
                <default>false</default>
                <label>Warning</label>
            </value>
            <value>
                <fullName>Error</fullName>
                <default>true</default>
                <label>Error</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
